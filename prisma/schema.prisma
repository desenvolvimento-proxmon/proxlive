generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String                  @unique
  passwordHash            String
  createdAt               DateTime                @default(now())
  studyPlans              StudyPlan[]
  recommendationHistories RecommendationHistory[]
  planQuestions           PlanQuestion[]
}

model StudyPlan {
  id                      String                  @id @default(cuid())
  userId                  String
  objective               String
  deadline                DateTime
  subjects                String
  availableDays           String
  hoursPerDay             Float
  level                   String
  preference              String
  aiResponse              String
  completedSessions       String                  @default("[]")
  createdAt               DateTime                @default(now())
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationHistories RecommendationHistory[]
  planQuestions           PlanQuestion[]

  @@index([userId])
}

model RecommendationHistory {
  id                 String    @id @default(cuid())
  userId             String
  studyPlanId        String
  recommendationText String
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlan          StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studyPlanId])
}

model PlanQuestion {
  id          String    @id @default(cuid())
  userId      String
  studyPlanId String
  question    String
  answer      String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlan   StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studyPlanId])
}
